# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — API is a fallback, scraper is primary
TWITTER_BEARER_TOKEN=

# Seed accounts — comma-separated known spam handles to start crawling from.
# The crawler also auto-seeds from previously blocked accounts in the DB.
SEED_ACCOUNTS=spambot1,spambot2,spambot3

# Popular accounts whose replies we scan for spam bots
REPLY_TARGET_ACCOUNTS=elonmusk,taylorswift13,BillGates,TheRock,Cristiano

# Target block list slug
TARGET_LIST_SLUG=spam-bots

# Scoring thresholds
AUTO_APPROVE_THRESHOLD=0.9
REVIEW_THRESHOLD=0.6

# Crawl behavior
SCAN_LIMIT=200
MAX_CRAWL_DEPTH=2
CRAWL_DELAY_MS=3000
REPLY_PAGE_SIZE=100

# Feature flags
ENABLE_GRAPH_CRAWL=true
ENABLE_REPLY_SCAN=true
ENABLE_SEARCH=false

# Set to true to test without writing to the database
DRY_RUN=false
