# Supabase connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Target list slug — accounts detected by the crawler will be added to this list
TARGET_LIST_SLUG=spam-bots

# Twitter API Bearer Token (from developer.twitter.com)
# Required for fetching user profiles and tweets
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Detection thresholds (0.0 to 1.0)
# Accounts scoring above this are added as 'active' (auto-approved)
AUTO_APPROVE_THRESHOLD=0.9
# Accounts scoring above this but below auto-approve go to 'under_review'
REVIEW_THRESHOLD=0.6

# How many accounts to scan per run
SCAN_LIMIT=100

# Dry run mode — log detections without writing to the database
DRY_RUN=false
