# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Crawler identity — the auth.users UUID that owns crawler-created records.
# Copy your admin user_id from the user_roles table in Supabase.
CRAWLER_USER_ID=

# Twitter cookie-based auth (RECOMMENDED — most reliable method)
# Get these from Chrome DevTools > Application > Cookies > x.com
# Log into Twitter/X in Chrome, then copy these two cookie values:
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Twitter account credentials (fallback if cookies not set)
# Use a burner/alt account, NOT your main account
TWITTER_USERNAME=
TWITTER_PASSWORD=

# Optional — API v2 bearer token as fallback
TWITTER_BEARER_TOKEN=

# Target block list slug
TARGET_LIST_SLUG=spam-bots

# Scoring thresholds
AUTO_APPROVE_THRESHOLD=0.75
REVIEW_THRESHOLD=0.4

# Crawl behavior
SCAN_LIMIT=500
CRAWL_DELAY_MS=1500

# Network expansion — crawl following lists of confirmed bots (best-effort, may 404)
ENABLE_NETWORK_EXPANSION=true

# Set to true to test without writing to the database
DRY_RUN=false
